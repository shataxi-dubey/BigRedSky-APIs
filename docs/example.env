# Core Settings
LOG_LEVEL=DEBUG
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8002

# Model Configuration - Use Local Model (Free)
USE_LOCAL_MODEL=true
LOCAL_MODEL_URL=http://127.0.0.1:1234

# Search Provider Configuration - Use DuckDuckGo (Free)
SEARCH_PROVIDER=duckduckgo
DUCKDUCKGO_MAX_RESULTS=10

# Optional: OpenAI Configuration (used when USE_LOCAL_MODEL=false)
# OPENAI_API_KEY=your_openai_api_key_here

# JD Creator model configuration
# JD_LLM_MODEL=gpt-4.1
# JD_LLM_MODEL_FAST=gpt-4.1-mini

# Optional: Tavily Configuration (used when SEARCH_PROVIDER=tavily)
# TAVILY_API_KEY=your_tavily_api_key_here

# Optional: Langfuse (Observability)
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# Redis (Caching & Rate Limiting) - Optional for development
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Monitoring - Optional
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Database (PostgreSQL — matches the postgres service in docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bigredsky

# Resume Parser - LLM models
RESUME_LLM_MODEL=gpt-4.1-mini
CHUNK_LLM_MODEL=gpt-4.1-mini

# Resume Parser - dense embedding model (Qwen3; vector dim is read from the model at runtime)
DENSE_EMBED_MODEL=Qwen/Qwen3-Embedding

# Resume Parser - sparse embedding model (SPLADE via sentence-transformers SparseEncoder)
SPARSE_EMBED_MODEL=naver/splade-v3

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=resume_chunks